# Copy this file to backend/.env and adjust as needed.
# Every value here has a sane default in backend/app/config.py — you only
# need this file to override something.

# --- Runtime mode ------------------------------------------------------
# true (default): every AI call is mocked - no inference servers needed,
#                  safe for local dev and the test suite.
# false: real calls go out per-role to whatever BASE_URL each role below
#        points at - see README.md "Going from mock to real models" first.
MOCK_MODE=true

# --- OCR / Vision model (only used when MOCK_MODE=false) ---------------
OCR_BASE_URL=http://localhost:11434/v1
OCR_API_KEY=ollama
OCR_MODEL=qwen3-vl:8b

# --- Generation / LLM (only used when MOCK_MODE=false) -----------------
GENERATION_BASE_URL=http://localhost:11434/v1
GENERATION_API_KEY=ollama
GENERATION_MODEL=gemma4:26b

# --- Embedding model (only used when MOCK_MODE=false) -------------------
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=bge-m3

# Optional. Leave unset to auto-detect from the first response (safe
# default for providers with a fixed native dimension, e.g. BGE-M3,
# Cohere, most self-hosted models). Set it ONLY if your model supports
# dimension truncation via the OpenAI `dimensions` request param (e.g.
# OpenAI text-embedding-3-*) — the client will validate the returned
# vector size matches and raise a clear error if the provider ignored
# the request.
# EMBEDDING_DIM=1024

# --- Retrieval tuning ----------------------------------------------------
RETRIEVAL_TOP_K=8
SCENARIO_HIGH_THRESHOLD=0.75
SCENARIO_MID_THRESHOLD=0.55
SCENARIO_LOW_THRESHOLD=0.35