# Copy this file to backend/.env and adjust as needed.
# Every value here has a sane default in backend/app/config.py — you only
# need this file to override something.

# --- Runtime mode ------------------------------------------------------
# true (default): every AI call is mocked - no GPU/Ollama needed, safe for
#                  local dev and the test suite.
# false: real calls go to Ollama at OLLAMA_BASE_URL - see README.md
#        "Going from mock to real models" before flipping this.
MOCK_MODE=true

# --- Ollama (only used when MOCK_MODE=false) ---------------------------
OLLAMA_BASE_URL=http://localhost:11434
OCR_MODEL=olmocr
GENERATION_MODEL=mistral-small
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024

# --- Retrieval tuning ----------------------------------------------------
RETRIEVAL_TOP_K=8
SCENARIO_HIGH_THRESHOLD=0.75
SCENARIO_MID_THRESHOLD=0.55
SCENARIO_LOW_THRESHOLD=0.35
